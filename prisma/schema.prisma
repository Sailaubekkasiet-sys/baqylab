generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ───────────────────────────────────────────────

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  passwordHash   String
  role             String           @default("STUDENT") // "TEACHER" | "STUDENT"
  avatarUrl        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Gamification (Phase 1)
  xp               Int              @default(0)
  level            Int              @default(1)
  streakDays       Int              @default(0)
  lastActiveAt     DateTime?
  academicStability Float           @default(1.0) // 0.0 to 1.0 multiplier

  // Relations
  ownedClasses     Class[]          @relation("ClassTeacher")
  memberships      ClassMember[]
  submissions      SubmissionVersion[]
  lineComments     LineComment[]
  materials        Material[]
  // Phase 4
  userSkills       UserSkill[]
  teamMemberships  TeamMember[]
  achievements     Achievement[]
  comments         Comment[]
  peerReviews      PeerReview[]
}

// ─── Achievements (Badges) ───────────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String   // e.g. "first_code", "10_streak", "perfect_score"
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, badgeId])
}

// ─── Classes ─────────────────────────────────────────────

model Class {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  inviteCode  String        @unique
  teacherId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  teacher     User          @relation("ClassTeacher", fields: [teacherId], references: [id])
  members     ClassMember[]
  lectures    Lecture[]
  assignments Assignment[]
  materials   Material[]
  teams       Team[]
}

model ClassMember {
  id        String   @id @default(cuid())
  userId    String
  classId   String
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
}

// ─── Lectures ────────────────────────────────────────────

model Lecture {
  id        String   @id @default(cuid())
  classId   String
  title     String
  content   String   @default("") // Markdown content
  resources String   @default("[]") // JSON array of {title, url}
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  comments  Comment[]
}

// ─── Skills ──────────────────────────────────────────────

model Skill {
  id          String            @id @default(cuid())
  name        String            @unique   // e.g. "OOP", "Loops", "SQL"
  description String            @default("")
  color       String            @default("#6366f1") // for UI badges
  assignments AssignmentSkill[]
  userSkills  UserSkill[]
}

model AssignmentSkill {
  id           String     @id @default(cuid())
  assignmentId String
  skillId      String

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, skillId])
}

// ─── Assignments ─────────────────────────────────────────

model Assignment {
  id              String              @id @default(cuid())
  classId         String
  title           String
  description     String              @default("") // Markdown
  dueDate         DateTime?
  language        String              @default("python") // python, javascript, html, sql
  type            String              @default("CODE") // "CODE" | "TEXT" | "QUIZ"
  textPrompt      String              @default("") // For text assignments
  quizData        String              @default("[]") // JSON array of quiz questions
  order           Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Auto-grading config (JSON stored as string)
  testCases       String              @default("[]")   // JSON: [{input, expectedOutput}]
  timeLimitMs     Int                 @default(5000)
  memoryLimitMb   Int                 @default(128)

  // Gamification & Advanced (Phase 1 & 4)
  difficulty      String              @default("BASIC") // "BASIC" | "MEDIUM" | "ADVANCED"
  xpReward        Int                 @default(100)
  
  // Phase 2: Teacher Tools
  // Phase 4: Smart Deadlines & Modes
  hardDeadline    DateTime?

  class           Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  skills          AssignmentSkill[]
  rubricCriteria  RubricCriterion[]
  selfCheckItems  SelfCheckItem[]
  submissions     SubmissionVersion[]
}

// ─── Rubric Criteria ─────────────────────────────────────

model RubricCriterion {
  id           String           @id @default(cuid())
  assignmentId String
  name         String           // e.g. "Code Style", "Correctness"
  description  String           @default("")
  maxPoints    Int              @default(10)
  type         String           @default("scale") // "scale" | "checkbox" | "text"
  order        Int              @default(0)

  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  grades       CriterionGrade[]
}

// ─── Self-Check Items ────────────────────────────────────

model SelfCheckItem {
  id           String     @id @default(cuid())
  assignmentId String
  label        String     // e.g. "I ran all unit tests"
  required     Boolean    @default(true)
  order        Int        @default(0)

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// ─── Submission Versions (Git-like) ──────────────────────

model SubmissionVersion {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  version      Int              @default(1)
  code         String           @default("") // The actual code content
  fileName     String           @default("solution.py")
  status       String           @default("draft") // "draft" | "submitted" | "graded"
  
  // For TEXT / QUIZ assignments and attachments
  answerText   String           @default("")
  quizAnswers  String           @default("{}") // JSON map of questionId -> selectedOptionIdx
  attachments  String           @default("[]") // JSON array of file URLs
  
  // Self-check completion (JSON: array of completed item IDs)
  selfChecks   String           @default("[]")
  
  // Auto-grading results (JSON)
  autoResults  String           @default("{}") // {passed: 5, total: 10, details: [...]}
  
  // Phase 3: Gallery
  isBestSolution Boolean        @default(false)

  createdAt    DateTime         @default(now())

  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lineComments LineComment[]
  grades       CriterionGrade[]
  peerReviews  PeerReview[]

  @@unique([assignmentId, studentId, version])
}

// ─── Line-by-Line Comments ──────────────────────────────

model LineComment {
  id           String            @id @default(cuid())
  submissionId String
  authorId     String
  lineNumber   Int
  text         String
  type         String            @default("tip") // "error" | "tip" | "good" | "think"
  createdAt    DateTime          @default(now())

  submission   SubmissionVersion @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author       User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── Criterion Grades ───────────────────────────────────

model CriterionGrade {
  id           String            @id @default(cuid())
  submissionId String
  criterionId  String
  points       Int               @default(0)
  comment      String            @default("")
  createdAt    DateTime          @default(now())

  submission   SubmissionVersion @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  criterion    RubricCriterion   @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, criterionId])
}

// ─── Materials ──────────────────────────────────────────

model Material {
  id          String   @id @default(cuid())
  classId     String
  uploaderId  String
  fileName    String
  fileSize    Int      @default(0)
  filePath    String   // path on disk
  mimeType    String   @default("application/octet-stream")
  createdAt   DateTime @default(now())

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  comments    Comment[]
}

// ─── Material / Lecture Comments (Phase 3) ───────────────

model Comment {
  id          String    @id @default(cuid())
  text        String
  authorId    String
  lectureId   String?
  materialId  String?
  parentId    String?
  createdAt   DateTime  @default(now())

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  lecture     Lecture?   @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  material    Material?  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  parent      Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]  @relation("CommentReplies")
}

// ─── Peer Reviews (Phase 3) ──────────────────────────────

model PeerReview {
  id           String   @id @default(cuid())
  submissionId String
  reviewerId   String
  rating       Int      @default(0) // 1-5
  comment      String   @default("")
  createdAt    DateTime @default(now())

  submission   SubmissionVersion @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer     User              @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
}

// ─── User Skills (Phase 4) ───────────────────────────────

model UserSkill {
  id        String   @id @default(cuid())
  userId    String
  skillId   String
  mastery   Int      @default(0) // 0-100 percentage
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

// ─── Teams (Phase 4) ─────────────────────────────────────

model Team {
  id          String       @id @default(cuid())
  classId     String
  name        String
  createdAt   DateTime     @default(now())

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  members     TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  joinedAt  DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}
